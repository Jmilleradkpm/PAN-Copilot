# Anthropic
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# Files
PROMPT_FILE=pan_copilot_system_prompt.md
STORE_FILE=knowledge_store.json
SOURCES_FILE=sources.json
BACKUP_DIR=backups
PENDING_DIR=pending
LOG_FILE=updater.log

# Models (judge runs per item, synth reserved for future compression pass)
JUDGE_MODEL=claude-haiku-4-5-20251001
SYNTH_MODEL=claude-sonnet-4-6

# Behavior
UPDATE_MODE=review
USEFULNESS_THRESHOLD=3
ADVISORY_TTL_DAYS=180
MAX_KNOWLEDGE_CHARS=12000
MAX_ITEMS_PER_SOURCE=25
HTTP_TIMEOUT=30

# Web + x.com discovery (Anthropic web_search tool)
ENABLE_DISCOVERY=true
DISCOVERY_MODEL=claude-sonnet-4-6
DISCOVERY_DAYS=14
DISCOVERY_MAX_SEARCHES=6
X_ALLOWED_DOMAINS=x.com,twitter.com,nitter.net

# Known-issues database + release-notes ingest
KNOWN_ISSUES_DB=known_issues.db
RELEASE_NOTES_SOURCES=release_notes_sources.json
INGEST_STATE=ingest_state.json

# Suspected-bug reporting (PAN CSP submission OFF by default)
PENDING_REPORTS_DIR=pending/reports
ENABLE_PAN_CASE_SUBMISSION=false

# Native X (Twitter) API v2 search (optional; default uses web-scoped search)
X_API_MODE=web
X_BEARER_TOKEN=
X_RECENT_SEARCH_URL=https://api.twitter.com/2/tweets/search/recent
X_MAX_TWEETS=25

# Known-issues API service
API_PORT=8088
